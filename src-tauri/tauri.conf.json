{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EQL Alerts",
  "mainBinaryName": "EQL Alerts",
  "version": "0.1.10",
  "identifier": "com.eqlegends.alerts",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EQL Alerts",
        "width": 1360,
        "height": 880,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "resources": ["binaries/eql-speak"],
    "shortDescription": "Log triggers and overlays for EverQuest Legends",
    "longDescription": "Tails your EverQuest Legends character log and fires lightweight text, timer, and sound alerts — a modern, no-frills GINA-style engine.",
    "macOS": {
      "bundleName": "EQL Alerts",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4QzU1RDRFOUExQjZCMzYKUldRMmF4dWFUbDNGeVBpSlJzaVdFRUlvbE0zQzZHU21sbG1VUnNqeHFOSDZWQ3kyd3pxVFUyN1cK",
      "endpoints": [
        "https://github.com/kpxcoolx/eql-alerts/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
